# =============================================================
# MalDeals Backend — Environment Variables
# Copy this file: cp .env.example .env
# Fill in all values and NEVER commit the .env file!
# =============================================================

# -------------------------------------------------------------
# 🗄️ Database (PostgreSQL)
# -------------------------------------------------------------
DATABASE_URL=Host=localhost;Port=5432;Database=deals_db;Username=malDeals;Password=your_password

POSTGRES_USER=malDeals
POSTGRES_PASSWORD=your_password
POSTGRES_DB=deals_db

# -------------------------------------------------------------
# 🔐 JWT Authentication
# -------------------------------------------------------------
# Random string of at least 32 characters
JWT_SECRET_KEY=your-super-secret-jwt-key-min-32-chars
JWT_ISSUER=MalDealsBackend
JWT_AUDIENCE=MalDealsClient
# Token expiry in minutes (default: 20160 = 14 days)
JWT_EXPIRY_MINUTES=20160

# -------------------------------------------------------------
# 🔑 API Key
# -------------------------------------------------------------
# HMAC secret used for API key generation and validation
API_KEY_SECRET_KEY=your-api-key-hmac-secret

# -------------------------------------------------------------
# 🖼️ MinIO (Object Storage / Image Upload)
# -------------------------------------------------------------
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=your_minio_password
# Internal container hostname (production: "minio", local: "localhost")
MINIO_ENDPOINT_CONTAINER=minio
